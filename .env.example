# AI Radar 推送配置（本地测试用，不上传 Git）
# 复制本文件为 .env（已被 .gitignore 忽略）

# 飞书机器人 webhook（可选）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook

# Server酱 sendkey（可选，微信服务号通知）
SERVERCHAN_KEY=SCT你的sendkey

# 自建 RSSHub 地址（本地 radar 测试 Twitter/小红书 时填写）
# 公众号可用公共实例；Twitter/小红书需自建，见 deploy/rsshub/README.md
RSSHUB_BASE_URL=http://localhost:1200
